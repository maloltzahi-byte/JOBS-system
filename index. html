<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>GEMS Master v1.19.1 - UI LOCKED</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Assistant:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f5f5f7;
    --panel: #ffffff;
    --panel-soft: #fafafc;
    --text: #1d1d1f;
    --muted: #6e6e73;
    --line: #e5e5ea;
    --blue: #0071e3;
    --blue-soft: #eef6ff;
    --green: #2ea043;
    --green-soft: #ebf8ee;
    --orange: #ff9f0a;
    --orange-soft: #fff6e8;
    --red: #d92d20;
    --red-soft: #fff1f0;
    --shadow: 0 12px 36px rgba(0,0,0,.06);
    --radius: 16px;
    --radius-sm: 12px;
    --header-h: 68px;
    --footer-h: 94px;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    font-family: 'Assistant', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow: hidden;
  }
  .app {
    height: 100vh;
    display: grid;
    grid-template-columns: 430px 1fr;
    overflow: hidden;
  }
  .left {
    background: var(--panel);
    border-left: 1px solid var(--line);
    box-shadow: var(--shadow);
    display: grid;
    grid-template-rows: var(--header-h) 1fr var(--footer-h);
    min-width: 0;
    min-height: 0;
  }
  .left-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 22px;
    border-bottom: 1px solid var(--line);
    background: rgba(255,255,255,.88);
    backdrop-filter: blur(10px);
  }
  .brand {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .brand strong { font-size: 20px; font-weight: 800; }
  .brand span { font-size: 11px; color: var(--muted); font-weight: 700; }
  .ver {
    padding: 6px 10px;
    border-radius: 999px;
    background: #f1f2f4;
    font-size: 11px;
    color: var(--muted);
    font-weight: 700;
    white-space: nowrap;
  }
  .left-body {
    padding: 24px 22px 18px;
    display: grid;
    grid-template-rows: auto auto 1fr auto;
    gap: 14px;
    min-height: 0;
  }
  .step-meta {
    font-size: 11px;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: .08em;
  }
  .step-title {
    margin: 0;
    font-size: 32px;
    line-height: 1.1;
    font-weight: 800;
    letter-spacing: -.03em;
    min-height: 70px;
  }
  .field-area {
    min-height: 0;
    display: flex;
    align-items: flex-start;
  }
  .field-stack {
    width: 100%;
    display: grid;
    gap: 12px;
    align-content: start;
  }
  .hint {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.45;
    min-height: 20px;
  }
  .text-input, .num-input {
    width: 100%;
    padding: 14px 16px;
    border-radius: 14px;
    border: 1px solid var(--line);
    background: var(--panel-soft);
    color: var(--text);
    font-size: 17px;
    font-weight: 600;
    transition: .18s ease;
  }
  .text-input:focus, .num-input:focus {
    outline: none;
    border-color: var(--blue);
    background: var(--panel);
    box-shadow: 0 0 0 4px rgba(0,113,227,.12);
  }
  .choice-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }
  .choice-grid.two { grid-template-columns: 1fr 1fr; }
  .choice-btn, .binary-btn {
    border: 1px solid var(--line);
    background: var(--panel-soft);
    border-radius: 14px;
    color: var(--text);
    cursor: pointer;
    transition: .18s ease;
    font-family: inherit;
    font-weight: 700;
  }
  .choice-btn {
    padding: 14px 14px;
    min-height: 58px;
    font-size: 15px;
    text-align: right;
  }
  .binary-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .binary-btn { padding: 14px 12px; font-size: 15px; min-height: 54px; }
  .choice-btn:hover, .binary-btn:hover { background: #f0f3f7; }
  .choice-btn.active, .binary-btn.active {
    background: var(--blue);
    border-color: var(--blue);
    color: #fff;
  }
  .validation {
    min-height: 18px;
    font-size: 12px;
    color: var(--red);
    font-weight: 700;
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .nav-btn {
    border: none;
    border-radius: 12px;
    padding: 12px 18px;
    font-size: 15px;
    font-weight: 800;
    cursor: pointer;
    transition: .18s ease;
    min-width: 104px;
  }
  .nav-btn.prev { background: #ececf1; color: var(--text); }
  .nav-btn.next { background: var(--blue); color: #fff; }
  .nav-btn:disabled { opacity: .4; cursor: not-allowed; }
  .dots {
    display: flex;
    gap: 6px;
    align-items: center;
    justify-content: center;
    flex: 1;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: #d7d7dc;
    transition: .18s ease;
  }
  .dot.active {
    width: 24px;
    background: var(--blue);
  }
  .left-foot {
    border-top: 1px solid var(--line);
    padding: 16px 22px;
    background: #fafafa;
    display: grid;
    gap: 10px;
    align-content: center;
  }
  .action-btn {
    width: 100%;
    border: none;
    border-radius: 14px;
    padding: 14px 16px;
    font-size: 15px;
    font-weight: 800;
    color: #fff;
    transition: .18s ease;
    cursor: pointer;
  }
  .action-btn.allow { background: #111; }
  .action-btn.review { background: var(--orange); }
  .action-btn.block { background: #b7b7be; cursor: not-allowed; }
  .gate-help {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.35;
    min-height: 16px;
  }

  .right {
    min-width: 0;
    min-height: 0;
    display: grid;
    grid-template-rows: var(--header-h) 1fr;
    overflow: hidden;
  }
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    border-bottom: 1px solid var(--line);
    background: rgba(255,255,255,.84);
    backdrop-filter: blur(10px);
  }
  .topbar-left {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: var(--muted);
    font-weight: 700;
  }
  .runtime { color: var(--blue); font-weight: 800; }
  .badge {
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .04em;
  }
  .badge.INIT { background: #f1f2f4; color: #6e6e73; }
  .badge.ALLOW { background: var(--green-soft); color: #1d7b36; }
  .badge.BLOCK { background: var(--red-soft); color: var(--red); }
  .badge.FIX_REQUIRED { background: #eef6ff; color: var(--blue); }
  .badge.REVIEW { background: var(--orange-soft); color: #b86a00; }

  .workspace {
    padding: 18px 18px 18px 22px;
    min-height: 0;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 14px;
    overflow: hidden;
  }
  .summary-grid {
    display: grid;
    grid-template-columns: 1.2fr .8fr;
    gap: 14px;
    min-height: 0;
  }
  .card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: 18px;
    box-shadow: var(--shadow);
    min-width: 0;
  }
  .card-head {
    padding: 14px 16px;
    border-bottom: 1px solid var(--line);
    font-size: 12px;
    font-weight: 800;
    color: var(--muted);
    letter-spacing: .05em;
  }
  .card-body { padding: 14px 16px; }
  .card.compact .card-body { padding: 12px 14px; }

  .issues-list {
    display: grid;
    gap: 10px;
    max-height: 184px;
    overflow: hidden;
  }
  .issue {
    border-radius: 12px;
    padding: 12px 12px;
    border: 1px solid transparent;
    display: grid;
    gap: 6px;
  }
  .issue.BLOCK { background: var(--red-soft); border-color: #ffd1cc; }
  .issue.FIX { background: var(--blue-soft); border-color: #cfe5ff; }
  .issue.REVIEW { background: var(--orange-soft); border-color: #ffe3b0; }
  .issue-title {
    font-size: 14px;
    font-weight: 800;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .issue-summary {
    font-size: 13px;
    line-height: 1.35;
  }
  .issue-resolution {
    font-size: 12px;
    color: var(--muted);
    font-weight: 700;
  }
  .ok-box {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--green-soft);
    border-radius: 12px;
    color: #1d7b36;
    font-weight: 800;
    min-height: 124px;
  }

  .state-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
  .kv {
    background: var(--panel-soft);
    border-radius: 12px;
    padding: 10px 12px;
    min-height: 58px;
  }
  .kv .k {
    font-size: 11px;
    color: var(--muted);
    font-weight: 800;
    margin-bottom: 4px;
  }
  .kv .v {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.2;
    word-break: break-word;
  }

  .preview {
    min-height: 0;
    display: grid;
    grid-template-rows: auto 1fr;
  }
  .preview-body {
    padding: 20px 22px;
    overflow: hidden;
    min-height: 0;
  }
  .doc-title {
    text-align: center;
    margin: 0 0 18px;
    font-size: 26px;
    font-weight: 800;
    letter-spacing: -.03em;
  }
  .clauses {
    display: grid;
    gap: 10px;
  }
  .clause {
    font-size: 14px;
    line-height: 1.45;
    background: var(--panel-soft);
    border-radius: 12px;
    padding: 12px 14px;
  }
  .hl { color: var(--blue); font-weight: 800; }
  .empty {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: var(--muted);
    gap: 10px;
  }
  .empty strong {
    color: var(--text);
    font-size: 20px;
    font-weight: 800;
  }
  .empty p {
    margin: 0;
    max-width: 540px;
    line-height: 1.45;
    font-size: 14px;
  }

  @media (max-width: 1200px) {
    .app { grid-template-columns: 400px 1fr; }
    .step-title { font-size: 28px; }
    .doc-title { font-size: 24px; }
  }
</style>
</head>
<body>
<div class="app">
  <aside class="left">
    <div class="left-head">
      <div class="brand">
        <strong>GEMS</strong>
        <span>UI LOCKED · ללא גלילה</span>
      </div>
      <div class="ver">v1.19.1</div>
    </div>

    <div class="left-body">
      <div class="step-meta" id="stepMeta">שלב 1</div>
      <h1 class="step-title" id="stepTitle">טוען…</h1>
      <div class="field-area">
        <div class="field-stack">
          <div id="fieldBox"></div>
          <div class="hint" id="fieldHint"></div>
          <div class="validation" id="validationMsg"></div>
        </div>
      </div>
      <div class="nav-row">
        <button class="nav-btn prev" id="prevBtn">הקודם</button>
        <div class="dots" id="dots"></div>
        <button class="nav-btn next" id="nextBtn">הבא</button>
      </div>
    </div>

    <div class="left-foot">
      <button class="action-btn block" id="releaseBtn" disabled>ממתין לנתונים</button>
      <div class="gate-help" id="gateHelp">המנוע הקנוני יכריע אחרי השלמת נתוני הליבה.</div>
    </div>
  </aside>

  <main class="right">
    <div class="topbar">
      <div class="topbar-left">GEMS <span class="runtime">@gems/legal-engine runtime</span></div>
      <div class="badge INIT" id="gateBadge">INIT</div>
    </div>

    <section class="workspace">
      <div class="summary-grid">
        <div class="card compact">
          <div class="card-head">LEGAL MATRIX / ISSUE REGISTRY</div>
          <div class="card-body" id="issuesWrap"></div>
        </div>
        <div class="card compact">
          <div class="card-head">STATE SNAPSHOT</div>
          <div class="card-body" id="stateWrap"></div>
        </div>
      </div>

      <div class="card preview">
        <div class="card-head">CONTRACT PREVIEW</div>
        <div class="preview-body" id="paperContainer"></div>
      </div>
    </section>
  </main>
</div>

<script>
const CalculationEngine = {
  calculateRelativeMinimumWage: (scopePercent) => Number((6443.85 * (scopePercent / 100)).toFixed(2)),
  calculateHourlyMinimum: () => 33.49
};

const ISSUE_REGISTRY_V2 = {
  issues: [
    {
      id: "ISSUE_MIN_WAGE_UNDERPAY",
      title: "שכר נמוך מהמינימום היחסי",
      domain: "Wages",
      severity: "BLOCK",
      summary: "השכר המוצע נמוך מהרף הקוגנטי הנדרש על פי חוק.",
      resolution_path: "יש לתקן את שכר הבסיס או את היקף המשרה המוגדר."
    },
    {
      id: "ISSUE_PENSION_MISSING",
      title: "חסרה הגדרת פנסיה",
      domain: "Pension",
      severity: "FIX",
      summary: "במסלול עובד לא הוגדרה זכאות לפנסיה חובה.",
      resolution_path: "חובה להפעיל את הגדרת הפנסיה כדי להתקדם."
    },
    {
      id: "ISSUE_CONTRACTOR_MISCLASSIFICATION",
      title: "סכנת סיווג יחסי עובד-מעסיק",
      domain: "Classification",
      severity: "REVIEW",
      summary: "התקשרות עם קבלן בהיקף 100% מעלה חשש כבד להכרה בו כעובד.",
      resolution_path: "נדרשת בחינה משפטית של עורך דין לאישור מתווה זה."
    },
    {
      id: "ISSUE_HOURLY_GLOBAL_CONFLICT",
      title: "מודל שעות נוספות שגוי",
      domain: "Hours",
      severity: "BLOCK",
      summary: "לא ניתן להחיל תמורת שעות נוספות גלובלית על עובד שעתי.",
      resolution_path: "יש לשנות את מודל השעות הנוספות ל'לפי חוק (בפועל)'."
    }
  ]
};

const LEGAL_MATRIX_V2 = {
  rules: [
    {
      id: "RULE_MIN_WAGE_PRO_RATA",
      route_scope: ["MONTHLY", "EXECUTIVE"],
      required_fields: ["compensation.salary", "employment.scopePercent"],
      applies_if: (state) => true,
      condition: (state) => state.compensation.salary < CalculationEngine.calculateRelativeMinimumWage(state.employment.scopePercent),
      actions: [{ type: "ADD_ISSUE", target: "ISSUE_MIN_WAGE_UNDERPAY" }]
    },
    {
      id: "RULE_HOURLY_MIN_WAGE",
      route_scope: ["HOURLY", "CONTRACTOR"],
      required_fields: ["compensation.salary"],
      applies_if: (state) => true,
      condition: (state) => state.compensation.salary < CalculationEngine.calculateHourlyMinimum(),
      actions: [{ type: "ADD_ISSUE", target: "ISSUE_MIN_WAGE_UNDERPAY" }]
    },
    {
      id: "RULE_PENSION_REQUIRED",
      route_scope: ["MONTHLY", "HOURLY", "EXECUTIVE"],
      required_fields: ["social.pensionEnabled"],
      applies_if: (state) => true,
      condition: (state) => state.social.pensionEnabled === false,
      actions: [{ type: "ADD_ISSUE", target: "ISSUE_PENSION_MISSING" }]
    },
    {
      id: "RULE_CONTRACTOR_FULL_SCOPE",
      route_scope: ["CONTRACTOR"],
      required_fields: ["employment.scopePercent"],
      applies_if: (state) => true,
      condition: (state) => state.employment.scopePercent >= 100,
      actions: [{ type: "ADD_ISSUE", target: "ISSUE_CONTRACTOR_MISCLASSIFICATION" }]
    },
    {
      id: "RULE_GLOBAL_OVERTIME_HOURLY",
      route_scope: ["HOURLY"],
      required_fields: ["hours.overtimeModel"],
      applies_if: (state) => true,
      condition: (state) => state.hours.overtimeModel === "GLOBAL",
      actions: [{ type: "ADD_ISSUE", target: "ISSUE_HOURLY_GLOBAL_CONFLICT" }]
    },
    {
      id: "CLAUSE_ASSEMBLY_ROUTING",
      route_scope: ["MONTHLY", "HOURLY", "EXECUTIVE", "CONTRACTOR"],
      required_fields: [],
      applies_if: (state) => true,
      condition: (state) => true,
      actions: [
        { type: "ADD_CLAUSE", target: "PREAMBLE" },
        { type: "ADD_CLAUSE", target: "PARTIES" },
        { type: "ADD_CLAUSE", target: "POSITION_DYNAMIC" },
        { type: "ADD_CLAUSE", target: "WAGE_DYNAMIC" }
      ]
    },
    {
      id: "CLAUSE_PENSION_MANDATORY",
      route_scope: ["MONTHLY", "HOURLY", "EXECUTIVE"],
      required_fields: ["social.pensionEnabled"],
      applies_if: (state) => state.social.pensionEnabled === true,
      condition: (state) => true,
      actions: [{ type: "ADD_CLAUSE", target: "PENSION_MANDATORY" }]
    },
    {
      id: "CLAUSE_SEC14",
      route_scope: ["MONTHLY", "EXECUTIVE"],
      required_fields: ["social.applySec14"],
      applies_if: (state) => state.social.applySec14 === true,
      condition: (state) => true,
      actions: [{ type: "ADD_CLAUSE", target: "SEC_14" }]
    },
    {
      id: "CLAUSE_GLOBAL_OVERTIME",
      route_scope: ["MONTHLY", "EXECUTIVE"],
      required_fields: ["hours.overtimeModel"],
      applies_if: (state) => state.hours.overtimeModel === "GLOBAL",
      condition: (state) => true,
      actions: [{ type: "ADD_CLAUSE", target: "OVERTIME_GLOBAL" }]
    },
    {
      id: "CLAUSE_TRUST",
      route_scope: ["EXECUTIVE"],
      required_fields: [],
      applies_if: (state) => true,
      condition: (state) => true,
      actions: [{ type: "ADD_CLAUSE", target: "TRUST_CLAUSE" }]
    }
  ]
};

function resolveGateStatus(severities) {
  if (severities.includes('BLOCK')) return 'BLOCK';
  if (severities.includes('FIX_REQUIRED') || severities.includes('FIX')) return 'FIX_REQUIRED';
  if (severities.includes('REVIEW_REQUIRED') || severities.includes('REVIEW')) return 'REVIEW';
  return 'ALLOW';
}

class GemsLegalEngineV1 {
  constructor() {
    this.registryMap = new Map(ISSUE_REGISTRY_V2.issues.map(issue => [issue.id, issue]));
  }

  evaluate(state) {
    const severities = [];
    const issues = [];
    const clauseActions = [];

    if (!state.basics.route || !state.basics.name || !state.basics.jobTitle || state.compensation.salary <= 0) {
      return { gateStatus: "INIT", issues: [], clauseActions: [] };
    }

    LEGAL_MATRIX_V2.rules.forEach(rule => {
      if (!rule.route_scope.includes(state.basics.route)) return;
      const hasFields = rule.required_fields.every(path => {
        const parts = path.split('.');
        let val = state;
        for (let p of parts) {
          if (val === undefined || val === null) return false;
          val = val[p];
        }
        return val !== undefined && val !== null && val !== '';
      });
      if (!hasFields) return;

      if (rule.applies_if(state) && rule.condition(state)) {
        rule.actions.forEach(action => {
          if (action.type === "ADD_ISSUE") {
            const issueDef = this.registryMap.get(action.target);
            if (issueDef) {
              issues.push(issueDef);
              severities.push(issueDef.severity);
            }
          }
          if (action.type === "ADD_CLAUSE") clauseActions.push({ action: "ADD", clauseId: action.target });
          if (action.type === "REMOVE_CLAUSE") clauseActions.push({ action: "REMOVE", clauseId: action.target });
        });
      }
    });

    return {
      gateStatus: resolveGateStatus(severities),
      issues,
      clauseActions
    };
  }
}

const canonicalEngine = new GemsLegalEngineV1();
const uiState = { currentStep: 0, answers: {} };

const QUESTION_SCHEMA = [
  { id: "route", title: "סוג התקשרות", type: "choice", required: true, hint: "בחר את המסלול המשפטי האמיתי של ההתקשרות.", options: [
    { value: "MONTHLY", label: "עובד חודשי" },
    { value: "HOURLY", label: "עובד שעתי" },
    { value: "EXECUTIVE", label: "בכיר / משרת אמון" },
    { value: "CONTRACTOR", label: "קבלן / B2B" }
  ]},
  { id: "name", title: "שם העובד/קבלן", type: "text", required: true, hint: "שם מלא כפי שיופיע בהסכם." },
  { id: "jobTitle", title: "הגדרת תפקיד", type: "text", required: true, hint: "תיאור תפקיד קצר ומדויק." },
  { id: "salary", title: "שכר בסיס / תעריף (₪)", type: "number", required: true, hint: "הזן את שכר הבסיס או התעריף השעתי." },
  { id: "scope", title: "היקף משרה (%)", type: "choice", required: true, hint: "בשלב זה התמיכה היא 50% או 100%.", options: [
    { value: "100", label: "מלאה (100%)" },
    { value: "50", label: "חלקית (50%)" }
  ], show_if: { route: ["MONTHLY", "CONTRACTOR"] }},
  { id: "overtime", title: "מודל שעות נוספות", type: "choice", required: true, hint: "הגדר האם מדובר בתשלום בפועל או במודל גלובלי.", options: [
    { value: "ACTUAL", label: "לפי חוק (בפועל)" },
    { value: "GLOBAL", label: "תמורה גלובלית" }
  ], show_if: { route: ["MONTHLY", "HOURLY", "EXECUTIVE"] }},
  { id: "pension", title: "הפרשות פנסיה", type: "boolean", required: true, hint: "חובה במסלול עובד.", show_if: { route: ["MONTHLY", "HOURLY", "EXECUTIVE"] }},
  { id: "sec14", title: "החלת סעיף 14 (פיצויים)?", type: "boolean", required: false, hint: "רלוונטי למסלולים חודשיים ובכירים.", show_if: { route: ["MONTHLY", "EXECUTIVE"] }}
];

const CLAUSE_TEXT_REGISTRY = {
  PREAMBLE: "הואיל והמעסיק מעוניין להעסיק את העובד, הכל בתנאים המפורטים להלן;",
  PARTIES: 'הסכם זה נערך ביום {{date}} בין החברה לבין {{name}}.',
  POSITION_DYNAMIC: 'מועסק בתפקיד {{jobTitle}} בהיקף של {{scope}}%.',
  WAGE_DYNAMIC: 'התמורה הינה בסך {{salary}} ₪.',
  OVERTIME_GLOBAL: 'תשולם תוספת גלובלית בגין שעות נוספות כחוק.',
  TRUST_CLAUSE: 'משרת אמון כמשמעותה בחוק שעות עבודה ומנוחה.',
  PENSION_MANDATORY: 'החברה תפריש לביטוח פנסיוני מקיף כקבוע בצו ההרחבה.',
  SEC_14: 'על הפרשות המעסיק יחולו הוראות סעיף 14 לחוק פיצויי פיטורים.'
};

function getVisibleSchema() {
  const r = uiState.answers.route;
  return QUESTION_SCHEMA.filter(q => !q.show_if || (q.show_if.route && q.show_if.route.includes(r)));
}

function buildContractState() {
  const ans = uiState.answers;
  return {
    basics: { route: ans.route, name: ans.name, jobTitle: ans.jobTitle },
    compensation: { salary: Number(ans.salary) || 0 },
    employment: { scopePercent: Number(ans.scope) || 100 },
    hours: { overtimeModel: ans.overtime || 'ACTUAL' },
    social: {
      pensionEnabled: ans.pension !== undefined ? ans.pension : true,
      applySec14: !!ans.sec14
    },
    protections: { hasNC: false, hasIP: false },
    classification: { trustJustification: null }
  };
}

function fillText(id, state) {
  return (CLAUSE_TEXT_REGISTRY[id] || '')
    .replace(/\{\{name\}\}/g, `<span class="hl">${state.basics.name || '___'}</span>`)
    .replace(/\{\{salary\}\}/g, `<span class="hl">${state.compensation.salary || '___'}</span>`)
    .replace(/\{\{jobTitle\}\}/g, `<span class="hl">${state.basics.jobTitle || '___'}</span>`)
    .replace(/\{\{scope\}\}/g, `<span class="hl">${state.employment.scopePercent || '___'}</span>`)
    .replace(/\{\{date\}\}/g, new Date().toLocaleDateString('he-IL'));
}

function validateCurrentStep() {
  const step = getVisibleSchema()[uiState.currentStep];
  if (!step || !step.required) return { ok: true, msg: '' };
  const v = uiState.answers[step.id];
  if (v === undefined || v === null || v === '') return { ok: false, msg: 'זה שדה חובה כדי להתקדם.' };
  return { ok: true, msg: '' };
}

function renderLeft(step, schema) {
  document.getElementById('stepMeta').textContent = `שלב ${uiState.currentStep + 1} מתוך ${schema.length}`;
  document.getElementById('stepTitle').textContent = step ? step.title : '';
  document.getElementById('fieldHint').textContent = step?.hint || '';
  document.getElementById('prevBtn').disabled = uiState.currentStep === 0;

  const validation = validateCurrentStep();
  document.getElementById('validationMsg').textContent = validation.msg;
  document.getElementById('nextBtn').disabled = !validation.ok || uiState.currentStep === schema.length - 1;
  document.getElementById('dots').innerHTML = schema.map((_, i) => `<span class="dot ${i === uiState.currentStep ? 'active' : ''}"></span>`).join('');

  if (!step) return;
  const val = uiState.answers[step.id];
  let html = '';

  if (step.type === 'choice') {
    const two = step.options.length === 2 ? 'two' : '';
    html = `<div class="choice-grid ${two}">${step.options.map(o => `<button class="choice-btn ${String(val) === String(o.value) ? 'active' : ''}" onclick="chooseValue('${step.id}','${o.value}')">${o.label}</button>`).join('')}</div>`;
  } else if (step.type === 'boolean') {
    html = `<div class="binary-wrap"><button class="binary-btn ${val === true ? 'active' : ''}" onclick="chooseBool('${step.id}', true)">כן</button><button class="binary-btn ${val === false ? 'active' : ''}" onclick="chooseBool('${step.id}', false)">לא</button></div>`;
  } else {
    const cls = step.type === 'number' ? 'num-input' : 'text-input';
    html = `<input id="liveInput" class="${cls}" type="${step.type}" value="${val ?? ''}" placeholder="הזן ערך...">`;
  }
  document.getElementById('fieldBox').innerHTML = html;

  const input = document.getElementById('liveInput');
  if (input) {
    input.addEventListener('input', (e) => {
      const value = step.type === 'number' ? e.target.value : e.target.value;
      uiState.answers[step.id] = value;
      renderDynamicOnly();
    });
  }
}

function renderOutputs(evalResult, contractState) {
  const badge = document.getElementById('gateBadge');
  badge.textContent = evalResult.gateStatus;
  badge.className = `badge ${evalResult.gateStatus}`;

  const relBtn = document.getElementById('releaseBtn');
  relBtn.className = `action-btn ${evalResult.gateStatus === 'ALLOW' ? 'allow' : evalResult.gateStatus === 'REVIEW' ? 'review' : 'block'}`;
  relBtn.disabled = evalResult.gateStatus !== 'ALLOW';
  relBtn.textContent = evalResult.gateStatus === 'ALLOW' ? 'הפקת הסכם סופי' : evalResult.gateStatus === 'REVIEW' ? 'ממתין לאישור עו״ד' : evalResult.gateStatus === 'INIT' ? 'השלם נתוני ליבה' : 'חסום: נדרש תיקון';

  const helper = document.getElementById('gateHelp');
  if (evalResult.gateStatus === 'ALLOW') helper.textContent = 'המערכת מאשרת הפקה. אפשר להמשיך למסמך.';
  else if (evalResult.gateStatus === 'REVIEW') helper.textContent = 'קיימת חשיפה שמחייבת אישור עו״ד לפני הפקה.';
  else if (evalResult.gateStatus === 'FIX_REQUIRED') helper.textContent = 'יש נתון חובה/תיקון נדרש לפני הפקה.';
  else if (evalResult.gateStatus === 'BLOCK') helper.textContent = 'המערכת זיהתה חסם משפטי קשיח.';
  else helper.textContent = 'המנוע הקנוני יכריע אחרי השלמת נתוני הליבה.';

  const issuesWrap = document.getElementById('issuesWrap');
  if (!evalResult.issues.length) {
    issuesWrap.innerHTML = `<div class="ok-box">אין כרגע issues פעילים</div>`;
  } else {
    issuesWrap.innerHTML = `<div class="issues-list">${evalResult.issues.map(i => `
      <div class="issue ${i.severity}">
        <div class="issue-title">${i.severity === 'BLOCK' ? '⛔' : i.severity === 'REVIEW' ? '⚠️' : '🔧'} ${i.title}</div>
        <div class="issue-summary">${i.summary}</div>
        <div class="issue-resolution">מה לתקן עכשיו: ${i.resolution_path}</div>
      </div>
    `).join('')}</div>`;
  }

  document.getElementById('stateWrap').innerHTML = `
    <div class="state-grid">
      <div class="kv"><div class="k">מסלול</div><div class="v">${contractState.basics.route || '—'}</div></div>
      <div class="kv"><div class="k">שכר/תעריף</div><div class="v">${contractState.compensation.salary || '—'}</div></div>
      <div class="kv"><div class="k">היקף</div><div class="v">${contractState.employment.scopePercent || '—'}%</div></div>
      <div class="kv"><div class="k">פנסיה</div><div class="v">${contractState.social.pensionEnabled === true ? 'כן' : contractState.social.pensionEnabled === false ? 'לא' : '—'}</div></div>
      <div class="kv"><div class="k">שעות נוספות</div><div class="v">${contractState.hours.overtimeModel || '—'}</div></div>
      <div class="kv"><div class="k">סעיף 14</div><div class="v">${contractState.social.applySec14 ? 'כן' : 'לא'}</div></div>
    </div>
  `;

  const paper = document.getElementById('paperContainer');
  if (evalResult.gateStatus === 'ALLOW') {
    const finalClauses = [];
    evalResult.clauseActions.forEach(action => {
      if (action.action === 'ADD' && !finalClauses.includes(action.clauseId)) finalClauses.push(action.clauseId);
      if (action.action === 'REMOVE') {
        const idx = finalClauses.indexOf(action.clauseId);
        if (idx !== -1) finalClauses.splice(idx, 1);
      }
    });
    paper.innerHTML = `
      <h2 class="doc-title">הסכם העסקה</h2>
      <div class="clauses">${finalClauses.map(id => `<div class="clause">${fillText(id, contractState)}</div>`).join('')}</div>
    `;
  } else {
    paper.innerHTML = `
      <div class="empty">
        <strong>המסמך עדיין נעול</strong>
        <p>${evalResult.gateStatus === 'INIT' ? 'יש להשלים שם, תפקיד, שכר ומסלול כדי להפעיל את המנוע.' : 'קיימות הערות מערכת הדורשות תיקון או בחינה משפטית לפני הרכבת ההסכם.'}</p>
      </div>
    `;
  }
}

function renderDynamicOnly() {
  const contractState = buildContractState();
  const evalResult = canonicalEngine.evaluate(contractState);
  const validation = validateCurrentStep();
  document.getElementById('validationMsg').textContent = validation.msg;
  document.getElementById('nextBtn').disabled = !validation.ok || uiState.currentStep === getVisibleSchema().length - 1;
  renderOutputs(evalResult, contractState);
}

function refreshUI(full = true) {
  const schema = getVisibleSchema();
  if (uiState.currentStep >= schema.length) uiState.currentStep = Math.max(0, schema.length - 1);
  const step = schema[uiState.currentStep];
  const contractState = buildContractState();
  const evalResult = canonicalEngine.evaluate(contractState);
  if (full) renderLeft(step, schema);
  renderOutputs(evalResult, contractState);
}

function chooseValue(key, value) {
  uiState.answers[key] = value;
  if (key === 'route') {
    ['scope', 'overtime', 'pension', 'sec14', 'salary'].forEach(k => delete uiState.answers[k]);
    uiState.currentStep = 0;
    while (getVisibleSchema()[uiState.currentStep]?.id !== 'name' && uiState.currentStep < getVisibleSchema().length - 1) uiState.currentStep++;
    refreshUI(true);
    return;
  }
  refreshUI(true);
}

function chooseBool(key, value) {
  uiState.answers[key] = value;
  refreshUI(true);
}

window.chooseValue = chooseValue;
window.chooseBool = chooseBool;

document.getElementById('prevBtn').onclick = () => {
  if (uiState.currentStep > 0) {
    uiState.currentStep--;
    refreshUI(true);
  }
};

document.getElementById('nextBtn').onclick = () => {
  const validation = validateCurrentStep();
  if (!validation.ok) {
    document.getElementById('validationMsg').textContent = validation.msg;
    return;
  }
  if (uiState.currentStep < getVisibleSchema().length - 1) {
    uiState.currentStep++;
    refreshUI(true);
  }
};

document.getElementById('releaseBtn').onclick = () => {
  const res = canonicalEngine.evaluate(buildContractState());
  if (res.gateStatus === 'ALLOW') window.print();
};

refreshUI(true);
</script>
</body>
</html>
